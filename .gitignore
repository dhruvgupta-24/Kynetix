# ─── Kynetix Root .gitignore ──────────────────────────────────────────────────

# ── Secrets & environment files — NEVER commit these ──────────────────────────
.env
.env.local
.env.development
.env.production
.env.*
*.secret
secrets.json
*.pem
*.key
supabase/.env
supabase/functions/.env

# ── Node / JS ─────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo

# ── Supabase ──────────────────────────────────────────────────────────────────
supabase/.branches
supabase/.temp
