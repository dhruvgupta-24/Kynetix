# ─── Kynetix Root .gitignore ──────────────────────────────────────────────────

# ── Secrets & environment files (NEVER commit) ────────────────────────────────
.env
.env.*
supabase/.env
supabase/functions/.env
*.secret
secrets.json
*.pem
*.key

# ── Debug / analysis / AI dump files ─────────────────────────────────────────
*.log
analysis*.txt
analyze*.txt
build*.txt
error*.txt
err*.txt
out*.txt
dart_analyze*.txt
output_*.txt
sha.txt
.gemini_*

# ── Temporary scripts ─────────────────────────────────────────────────────────
fix_*.py
run_*.py

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyc

# ── Supabase ──────────────────────────────────────────────────────────────────
supabase/.branches
supabase/.temp
